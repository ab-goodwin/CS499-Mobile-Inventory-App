<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Search, sort, and low-stock controls -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <Switch
            android:id="@+id/lowStockSwitch"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:showText="false"
            android:text="Low Stock Only"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Spinner
            android:id="@+id/sortSpinner"
            android:layout_width="180dp"
            android:layout_height="48dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/searchField"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:hint="Search Inventory Item"
            android:padding="8dp"
            app:layout_constraintEnd_toStartOf="@+id/searchButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lowStockSwitch" />

        <Button
            android:id="@+id/searchButton"
            android:layout_width="96dp"
            android:layout_height="48dp"
            android:text="Search"
            app:layout_constraintBottom_toBottomOf="@+id/searchField"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/searchField" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="INVENTORY"
        android:textAppearance="@style/TextAppearance.AppCompat.Body2"
        android:textSize="16sp"
        android:textStyle="bold" />

    <GridView
        android:id="@+id/gridView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:columnWidth="0dp"
        android:gravity="center"
        android:horizontalSpacing="10dp"
        android:numColumns="1"
        android:stretchMode="columnWidth"
        android:verticalSpacing="10dp" />

    <!-- Top-level menu buttons -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/actionButtonLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/updateDataButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Update"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/newItemButton"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/newItemButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/updateDataButton"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Add new item form -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/addItemForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/addItemName"
            android:layout_width="150dp"
            android:layout_height="48dp"
            android:hint="Item Name"
            android:padding="8dp"
            app:layout_constraintEnd_toStartOf="@+id/addCategory"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/addCategory"
            android:layout_width="150dp"
            android:layout_height="48dp"
            android:hint="Category"
            android:padding="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/addItemName"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/addQuantity"
            android:layout_width="150dp"
            android:layout_height="48dp"
            android:hint="Quantity"
            android:inputType="number"
            android:padding="8dp"
            app:layout_constraintEnd_toStartOf="@+id/addLowStockLimit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/addItemName" />

        <EditText
            android:id="@+id/addLowStockLimit"
            android:layout_width="150dp"
            android:layout_height="48dp"
            android:hint="Low Stock Limit"
            android:inputType="number"
            android:padding="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/addQuantity"
            app:layout_constraintTop_toBottomOf="@+id/addCategory" />

        <Button
            android:id="@+id/addItemSubmitButton"
            android:layout_width="120dp"
            android:layout_height="49dp"
            android:layout_marginTop="8dp"
            android:text="Add +"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/addQuantity" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Update selected item form -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/updateItemForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/updateItemName"
            android:layout_width="150dp"
            android:layout_height="48dp"
            android:hint="Item Name"
            android:padding="8dp"
            app:layout_constraintEnd_toStartOf="@+id/updateCategory"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/updateCategory"
            android:layout_width="150dp"
            android:layout_height="48dp"
            android:hint="Category"
            android:padding="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/updateItemName"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/updateQuantity"
            android:layout_width="150dp"
            android:layout_height="48dp"
            android:hint="Quantity"
            android:inputType="number"
            android:padding="8dp"
            app:layout_constraintEnd_toStartOf="@+id/updateLowStockLimit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/updateItemName" />

        <EditText
            android:id="@+id/updateLowStockLimit"
            android:layout_width="150dp"
            android:layout_height="48dp"
            android:hint="Low Stock Limit"
            android:inputType="number"
            android:padding="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/updateQuantity"
            app:layout_constraintTop_toBottomOf="@+id/updateCategory" />

        <Button
            android:id="@+id/decreaseQuantityButton"
            android:layout_width="120dp"
            android:layout_height="49dp"
            android:layout_marginTop="8dp"
            android:text="- 1"
            app:layout_constraintEnd_toStartOf="@+id/increaseQuantityButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/updateQuantity" />

        <Button
            android:id="@+id/increaseQuantityButton"
            android:layout_width="120dp"
            android:layout_height="49dp"
            android:layout_marginTop="8dp"
            android:text="+ 1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/decreaseQuantityButton"
            app:layout_constraintTop_toBottomOf="@+id/updateLowStockLimit" />

        <Button
            android:id="@+id/updateItemSubmitButton"
            android:layout_width="120dp"
            android:layout_height="49dp"
            android:layout_marginTop="8dp"
            android:text="Confirm"
            app:layout_constraintEnd_toStartOf="@+id/deleteItemButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/decreaseQuantityButton" />

        <Button
            android:id="@+id/deleteItemButton"
            android:layout_width="120dp"
            android:layout_height="49dp"
            android:layout_marginTop="8dp"
            android:text="Delete ╳"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/updateItemSubmitButton"
            app:layout_constraintTop_toBottomOf="@+id/increaseQuantityButton" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>